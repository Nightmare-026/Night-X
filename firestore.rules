rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow users to read and write only their own document in the 'users' collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Protect feedback collection from scrapers: Allow Create only, Deny Read/Update/Delete
    match /feedbacks/{feedbackId} {
      allow create: if request.resource.data.message.size() < 5000 
                    && request.resource.data.name.size() < 200;
      allow read, update, delete: if false;
    }
    
    // Deny all other access by default for enhanced security
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
